{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "021/laravel-wallet": "8.*",
        "andrewdwallo/filament-selectify": "^2.0",
        "archilex/filament-filter-sets": "^3.6",
        "awcodes/filament-table-repeater": "^3.0",
        "awcodes/filament-tiptap-editor": "^3.0",
        "bezhansalleh/filament-google-analytics": "^2.0",
        "bezhansalleh/filament-language-switch": "^3.0",
        "bezhansalleh/filament-shield": "^3.2",
        "cheesegrits/filament-google-maps": "^3.0",
        "clickpaysa/laravel_package": "*",
        "codewithdennis/filament-select-tree": "^3.1",
        "croustibat/filament-jobs-monitor": "^2.5",
        "diglactic/laravel-breadcrumbs": "^9.0",
        "filament/spatie-laravel-media-library-plugin": "^3.2",
        "filament/spatie-laravel-settings-plugin": "^3.2",
        "filament/spatie-laravel-translatable-plugin": "^3.2",
        "firebase/php-jwt": "^6.11",
        "flowframe/laravel-trend": "^0.2.0",
        "guava/filament-icon-picker": "^2.0",
        "guzzlehttp/guzzle": "^7.2",
        "hasan-ahani/filament-otp-input": "^1.0",
        "hasnayeen/themes": "^3.0",
        "hibit-dev/geodetect": "^2.0",
        "husam-tariq/filament-timepicker": "^3.0",
        "jeffgreco13/filament-breezy": "^2.4",
        "kreait/laravel-firebase": "^5.9",
        "lara-zeus/sky": "dev-main",
        "laravel/cashier": "^15.3",
        "laravel/framework": "^11",
        "laravel/octane": "^2.5",
        "laravel/reverb": "^1.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.8",
        "livewire/livewire": "3.5.12",
        "malzariey/filament-daterangepicker-filter": "dev-main",
        "michael-rubel/laravel-couponables": "^9.0",
        "mokhosh/filament-rating": "^1.1",
        "mvenghaus/filament-plugin-translatable-inline": "^3.0",
        "openai-php/client": "^0.10.1",
        "openai-php/laravel": "^0.10.1",
        "orangehill/iseed": "^3.0",
        "outhebox/blade-flags": "^1.5",
        "ryangjchandler/blade-tabler-icons": "^2.3",
        "solution-forest/filament-tree": "^2.0",
        "spatie/laravel-activitylog": "^4.8",
        "stevebauman/location": "^7.2",
        "swisnl/filament-backgrounds": "^1.1",
        "tapp/filament-auditing": "^3.0",
        "ysfkaya/filament-phone-input": "^2.3"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.13",
        "fakerphp/faker": "^1.9.1",
        "filament/filament": "^v3.2.73",
        "laravel/boost": "^1.1",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^10.1",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "exclude-from-classmap": [
            "vendor/cheesegrits/filament-google-maps/src/Fields/Geocomplete.php",
            "vendor/cheesegrits/filament-google-maps/src/Fields/Map.php",
            "vendor/bezhansalleh/filament-language-switch/src/Http/Middleware/SwitchLanguageLocale.php"
        ],
        "files": [
            "app/helpers.php",
            "Overrides/SwitchLanguageLocale.php"
        ]
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://filament-filter-sets.composer.sh"
        },
        {
            "type": "path",
            "url": "libraries/lara-zeus/sky"
        },
        {
            "type": "path",
            "url": "libraries/clickpaysa/"
        }
    ],
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade",
            "npm run build"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan filament:upgrade"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
